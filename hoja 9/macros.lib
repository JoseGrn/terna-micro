;*********************************************************************
;Macro: ImpresionOperaciones
;Descripciˇn: Imprime multiplicacion y division
;Parßmetros: Resultado y cadena de texto
;*********************************************************************
	ImpresionOperaciones Macro Res, Cadena
		; MOSTRAR TEXTO RESULTADO
		MOV AH, 09H
		LEA DX, Cadena
		INT 21H

		; MOSTRAR RESULTADO
		MOV AL, Res
		MOV AH, 0
		MOV BL, 10
		DIV BL
		
		MOV BH, AH
		
		ADD AL, 30H
		MOV DL, AL
		MOV AH, 02H
		INT 21H
		
		MOV DL, BH
		ADD DL, 30H
		MOV AH, 02H
		INT 21H
	ENDM ImpresionOperaciones